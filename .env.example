# === Required ===
# None required for basic operation — app works out of the box with OpenStreetMap

# === Optional: Real transit data (Navitia.io) ===
# Free tier: 3000 req/day. Register at https://navitia.io
NAVITIA_API_KEY=

# === Optional: Authentication (NextAuth) ===
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# === Optional: Payments (Stripe) ===
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# === Optional: Database (Railway auto-sets this) ===
DATABASE_URL=postgresql://user:pass@host:5432/transitflow

# === Optional: Better map tiles (Mapbox) ===
NEXT_PUBLIC_MAPBOX_TOKEN=
